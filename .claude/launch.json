{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev", "--port", "3333"],
      "port": 3333
    },
    {
      "name": "Inngest Dev Server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "dlx",
        "inngest-cli@latest",
        "dev",
        "-u",
        "http://localhost:3000/api/inngest"
      ],
      "port": 8288
    },
    {
      "name": "Drizzle Studio",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["drizzle-kit", "studio"],
      "port": 4983
    },
    {
      "name": "Vitest Watch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["vitest"],
      "port": 51204
    }
  ]
}
